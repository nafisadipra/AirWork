{
  "name": "airwork",
  "version": "1.0.0",
  "description": "Secure offline-first collaboration platform with end-to-end encryption",
  "main": "dist-electron/main.js",
  "author": "Your Name",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:electron\"",
    "dev:next": "next dev --turbopack",
    "dev:electron": "wait-on http://localhost:3000 && tsc -p electron/tsconfig.json && electron .",
    "build": "npm run build:next && npm run build:electron && electron-builder",
    "build:next": "next build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:mac": "npm run build:next && npm run build:electron && electron-builder --mac",
    "build:win": "npm run build:next && npm run build:electron && electron-builder --win",
    "build:linux": "npm run build:next && npm run build:electron && electron-builder --linux",
    "build:all": "npm run build:next && npm run build:electron && electron-builder -mwl",
    "start": "electron .",
    "test": "jest",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "rebuild": "electron-rebuild",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@node-rs/argon2": "^1.8.3",
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-collaboration": "^2.27.2",
    "@tiptap/extension-collaboration-cursor": "^2.9.1",
    "@tiptap/extension-list": "2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/extension-text-align": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "better-sqlite3-multiple-ciphers": "^12.8.0",
    "bip39": "^3.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.2.2",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "geist": "^1.3.1",
    "idb": "^8.0.0",
    "lib0": "^0.2.97",
    "lucide-react": "^0.460.0",
    "next": "^16.1.6",
    "noise-protocol": "3.0.2",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sodium-native": "^5.1.0",
    "tailwind-merge": "^2.5.5",
    "uuid": "^11.0.2",
    "y-indexeddb": "^9.0.12",
    "y-prosemirror": "^1.3.7",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.30",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.11",
    "@types/bip39": "^2.4.2",
    "@types/node": "^22.9.3",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.1.6",
    "jest": "^29.7.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.airwork.app",
    "productName": "AirWork",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist-electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
